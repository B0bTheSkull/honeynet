# Copy to /etc/honeynet-sentinel.env on the VPS and chmod 600.
# This file holds secrets -- it must NEVER be committed to git.
#
#   sudo cp honeynet-sentinel.env.example /etc/honeynet-sentinel.env
#   sudo chmod 600 /etc/honeynet-sentinel.env
#   sudo nano /etc/honeynet-sentinel.env   # fill in the two values below

# Sentinel webhook endpoint -- use the Pi's TAILNET address, not a public one.
# e.g. http://raspberrypi.<your-tailnet>.ts.net:8787/honeynet
SENTINEL_WEBHOOK_URL=

# Shared secret Sentinel checks on the Authorization: Bearer header.
SENTINEL_TOKEN=

# --- Optional tuning (defaults shown) ---
# HONEYNET_LOG=/opt/honeynet/logs/honeynet.json
# STATE_FILE=/var/lib/honeynet-sentinel/state.json
# MIN_UNIQUE_IPS=15
# MIN_TOTAL_EVENTS=250
#
# Transport: prefer a plain http:// tailnet URL -- Tailscale already encrypts
# the link end-to-end. If you front Sentinel with https://, it must present a
# valid cert (verification is always enforced; there is no insecure bypass).
